# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/laundry_db

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Firebase Cloud Messaging ──────────────────────────────────────────────
# Path to the service-account JSON downloaded from Firebase console.
# Firebase → Project Settings → Service accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# ── Slot Rules ────────────────────────────────────────────────────────────
MONTHLY_SLOT_QUOTA_PER_STUDENT=4
# Per-block daily limits (optional — defaults to 30)
# BLOCK_SLOT_LIMITS={"A": 30, "B": 25}

# ── App ───────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8100
